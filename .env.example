# Copia este archivo como ".env" antes de levantar el proyecto
# Dentro de docker-compose, el host de la base de datos es el nombre del servicio: "db"
#
# IMPORTANTE: si tu contraseña real de Postgres no es "5432", cámbiala aquí abajo.
# "5432" es también el puerto por defecto de Postgres, así que si copiaste esto
# de otro lado, es un error común confundir password con puerto.

DATABASE_URL=postgresql://postgres:5432@db:5432/postgres
